{
  "uid": "platform-health",
  "title": "Platform Health",
  "tags": ["platform", "overview"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Scrape targets up",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [
        { "color": "red", "value": null }, { "color": "yellow", "value": 1 }, { "color": "green", "value": 0.999 } ] },
        "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [ { "refId": "A", "expr": "avg(up)" } ]
    },
    {
      "id": 2, "type": "stat", "title": "Targets down",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [
        { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } },
      "targets": [ { "refId": "A", "expr": "count(up == 0) or vector(0)" } ]
    },
    {
      "id": 3, "type": "stat", "title": "Airflow scheduler heartbeat (rate)",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [
        { "color": "red", "value": null }, { "color": "green", "value": 0.0001 } ] }, "unit": "hertz" } },
      "targets": [ { "refId": "A", "expr": "rate(airflow_scheduler_heartbeat_total[5m])" } ]
    },
    {
      "id": 4, "type": "stat", "title": "Total Kafka consumer lag",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 10000 }, { "color": "red", "value": 100000 } ] } } },
      "targets": [ { "refId": "A", "expr": "sum(kafka_consumergroup_lag) or vector(0)" } ]
    },
    {
      "id": 5, "type": "timeseries", "title": "Container CPU (cores)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A",
        "expr": "sum(rate(container_cpu_usage_seconds_total{name=~\"payments-.*\"}[5m])) by (name)",
        "legendFormat": "{{name}}" } ]
    },
    {
      "id": 6, "type": "timeseries", "title": "Container memory (bytes)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [ { "refId": "A",
        "expr": "container_memory_usage_bytes{name=~\"payments-.*\"}",
        "legendFormat": "{{name}}" } ]
    },
    {
      "id": 7, "type": "timeseries", "title": "API p99 latency by service",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [ { "refId": "A",
        "expr": "histogram_quantile(0.99, sum(rate(api_request_duration_seconds_bucket[5m])) by (le, service))",
        "legendFormat": "{{service}}" } ]
    },
    {
      "id": 8, "type": "timeseries", "title": "API request rate by service",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [ { "refId": "A",
        "expr": "sum(rate(api_requests_total[5m])) by (service)",
        "legendFormat": "{{service}}" } ]
    },
    {
      "id": 9, "type": "timeseries", "title": "Kafka consumer lag by topic",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A",
        "expr": "sum(kafka_consumergroup_lag) by (topic)",
        "legendFormat": "{{topic}}" } ]
    },
    {
      "id": 10, "type": "timeseries", "title": "ClickHouse running queries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "ClickHouseMetrics_Query", "legendFormat": "running" },
        { "refId": "B", "expr": "rate(ClickHouseProfileEvents_Query[5m])", "legendFormat": "queries/s" }
      ]
    }
  ]
}
