<mxfile host="app.diagrams.net" agent="payment-platform" version="24.0.0">
  <diagram name="Support Flow" id="support-flow">
    <mxGraphModel dx="1100" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Support Ticket Lifecycle, SLA &amp; Escalation" style="text;html=1;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="500" height="30" as="geometry" />
        </mxCell>

        <mxCell id="raise" value="Ticket raised&#10;(merchant / customer)&#10;category + priority" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="90" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="sla" value="Start SLA clock&#10;sla_tracking&#10;(target by priority)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="320" y="90" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="prio" value="Priority?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="580" y="85" width="160" height="80" as="geometry" />
        </mxCell>

        <mxCell id="l1" value="Tier 1&#10;scripted resolution" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="800" y="60" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="l2" value="Tier 2&#10;payments specialist" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="800" y="130" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="l3" value="Tier 3&#10;engineering / finance ops&#10;(links to settlement_exceptions)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="800" y="200" width="200" height="70" as="geometry" />
        </mxCell>

        <mxCell id="esc" value="Escalation?&#10;(SLA risk / needs higher tier)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="560" y="280" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="escrow" value="ticket_escalations&#10;(level, escalated_to)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="820" y="290" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="resolve" value="Resolved&#10;set resolved_at&#10;check SLA breach" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="320" y="290" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="reopen" value="Reopened?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="80" y="285" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="close" value="Closed&#10;(confirmed / auto after N days)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="420" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="sink" value="support_events &#8594; Kafka &#8594;&#10;fact_support_events (ClickHouse)&#10;&#8594; Support dashboard (SLA, volume, escalation)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="320" y="420" width="380" height="70" as="geometry" />
        </mxCell>

        <!-- edges -->
        <mxCell id="u1" style="endArrow=block;html=1;" edge="1" parent="1" source="raise" target="sla"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="u2" style="endArrow=block;html=1;" edge="1" parent="1" source="sla" target="prio"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="u3" value="low/med" style="endArrow=block;html=1;" edge="1" parent="1" source="prio" target="l1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="u4" value="high/urgent" style="endArrow=block;html=1;" edge="1" parent="1" source="prio" target="l2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="u5" style="endArrow=block;html=1;" edge="1" parent="1" source="l1" target="esc"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="u6" style="endArrow=block;html=1;" edge="1" parent="1" source="l2" target="esc"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="u7" value="yes" style="endArrow=block;html=1;strokeColor=#b85450;" edge="1" parent="1" source="esc" target="escrow"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="u8" style="endArrow=block;html=1;" edge="1" parent="1" source="escrow" target="l3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="u9" value="no" style="endArrow=block;html=1;strokeColor=#82b366;" edge="1" parent="1" source="esc" target="resolve"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="u10" style="endArrow=block;html=1;" edge="1" parent="1" source="resolve" target="reopen"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="u11" value="no" style="endArrow=block;html=1;" edge="1" parent="1" source="reopen" target="close"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="u12" value="yes" style="endArrow=block;html=1;dashed=1;" edge="1" parent="1" source="reopen" target="resolve"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="u13" style="endArrow=block;html=1;strokeColor=#9673a6;" edge="1" parent="1" source="close" target="sink"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
