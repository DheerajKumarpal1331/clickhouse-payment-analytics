<mxfile host="app.diagrams.net" agent="payment-platform" version="24.0.0">
  <diagram name="Settlement Flow" id="settlement-flow">
    <mxGraphModel dx="1100" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="780" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="T+1 Settlement Batch &amp; Reconciliation" style="text;html=1;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="500" height="30" as="geometry" />
        </mxCell>

        <mxCell id="sched" value="Airflow Settlement DAG&#10;(daily cut-off, settlement_window)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;" vertex="1" parent="1">
          <mxGeometry x="60" y="90" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="open" value="Open batch&#10;settlement_batches(cycle_date)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="360" y="90" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="sum" value="Sum captured txns&#10;per merchant since last cycle&#10;(ClickHouse fact_transactions)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="660" y="85" width="260" height="70" as="geometry" />
        </mxCell>

        <mxCell id="net" value="Netting&#10;net = gross − MDR − GST&#10;− refunds − chargebacks − reserve&#10;&#8594; merchant_settlements" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="660" y="200" width="260" height="90" as="geometry" />
        </mxCell>
        <mxCell id="transfer" value="Initiate bank transfer&#10;NEFT / RTGS / IMPS&#10;&#8594; bank_transfers (UTR)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="360" y="205" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="bank" value="Sponsor Bank&#10;processes payout" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1">
          <mxGeometry x="60" y="210" width="240" height="60" as="geometry" />
        </mxCell>

        <mxCell id="stmt" value="End-of-day bank statement" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="1">
          <mxGeometry x="60" y="330" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="recon" value="Reconciliation&#10;expected vs actual&#10;&#8594; reconciliation_results (variance)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="360" y="325" width="240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="match" value="Matched?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="680" y="320" width="160" height="80" as="geometry" />
        </mxCell>

        <mxCell id="paid" value="status = paid&#10;set paid_at, tat_minutes&#10;&#8594; report + UTR to merchant" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="640" y="450" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="exc" value="settlement_exceptions&#10;(bank reject / mismatch / hold)&#10;&#8594; finance ops + support ticket" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="360" y="450" width="240" height="70" as="geometry" />
        </mxCell>

        <mxCell id="chsink" value="settlement_events &#8594; Kafka &#8594;&#10;fact_settlements (ClickHouse)&#10;&#8594; Settlement dashboard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="640" y="560" width="260" height="70" as="geometry" />
        </mxCell>

        <!-- edges -->
        <mxCell id="s1" style="endArrow=block;html=1;" edge="1" parent="1" source="sched" target="open"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s2" style="endArrow=block;html=1;" edge="1" parent="1" source="open" target="sum"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s3" style="endArrow=block;html=1;" edge="1" parent="1" source="sum" target="net"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s4" style="endArrow=block;html=1;" edge="1" parent="1" source="net" target="transfer"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s5" style="endArrow=block;html=1;" edge="1" parent="1" source="transfer" target="bank"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s6" style="endArrow=block;html=1;" edge="1" parent="1" source="bank" target="stmt"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s7" style="endArrow=block;html=1;" edge="1" parent="1" source="stmt" target="recon"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s8" style="endArrow=block;html=1;" edge="1" parent="1" source="recon" target="match"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s9" value="yes" style="endArrow=block;html=1;strokeColor=#82b366;" edge="1" parent="1" source="match" target="paid"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s10" value="no" style="endArrow=block;html=1;strokeColor=#b85450;" edge="1" parent="1" source="match" target="exc"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s11" style="endArrow=block;html=1;strokeColor=#9673a6;" edge="1" parent="1" source="paid" target="chsink"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
