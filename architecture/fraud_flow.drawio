<mxfile host="app.diagrams.net" agent="payment-platform" version="24.0.0">
  <diagram name="Fraud Detection Flow" id="fraud-flow">
    <mxGraphModel dx="1100" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Real-Time Fraud Detection &amp; Case Management" style="text;html=1;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="500" height="30" as="geometry" />
        </mxCell>

        <mxCell id="evt" value="transaction_event" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="90" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- Layer 1 rules -->
        <mxCell id="rules" value="Rules Engine (Layer 1)&#10;blacklists · velocity limit&#10;ticket limit · geo block" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="280" y="80" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="hardblock" value="HARD BLOCK&#10;+ open fraud_alert" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="290" y="200" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- feature lookup -->
        <mxCell id="feat" value="Online Feature Store&#10;(ClickHouse agg_velocity_5m,&#10;mv_fraud_features)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="540" y="80" width="220" height="70" as="geometry" />
        </mxCell>

        <!-- ML model -->
        <mxCell id="model" value="ML Model (Layer 2)&#10;XGBoost / LightGBM&#10;predict_proba + SHAP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="820" y="80" width="220" height="70" as="geometry" />
        </mxCell>

        <!-- score + bands -->
        <mxCell id="score" value="Fraud Score 0–1&#10;+ reason codes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="840" y="210" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="band" value="Risk Band (dim_risk_levels)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="820" y="320" width="220" height="100" as="geometry" />
        </mxCell>

        <!-- decisions -->
        <mxCell id="allow" value="low/medium&#10;ALLOW (+ monitor)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="600" y="330" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="stepup" value="high&#10;STEP-UP AUTH / HOLD" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="600" y="390" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="critical" value="critical&#10;BLOCK + open case" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="600" y="450" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- persistence + case mgmt -->
        <mxCell id="store" value="fraud_scores (async write)&#10;+ fact_fraud_events" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="840" y="470" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="case" value="Case Management&#10;fraud_alerts &#8594; fraud_cases&#10;&#8594; investigations &#8594; finding" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="280" y="450" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="label" value="Confirmed label&#10;&#8594; retrain (MLflow)&#10;&#8594; blacklist / suspend merchant" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="450" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="cb" value="Chargeback (weeks later)&#10;reason=fraud &#8594; delayed label" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="560" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- edges -->
        <mxCell id="f1" style="endArrow=block;html=1;" edge="1" parent="1" source="evt" target="rules"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f2" value="fail" style="endArrow=block;html=1;strokeColor=#b85450;" edge="1" parent="1" source="rules" target="hardblock"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f3" value="pass" style="endArrow=block;html=1;" edge="1" parent="1" source="rules" target="feat"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f4" style="endArrow=block;html=1;" edge="1" parent="1" source="feat" target="model"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f5" style="endArrow=block;html=1;" edge="1" parent="1" source="model" target="score"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f6" style="endArrow=block;html=1;" edge="1" parent="1" source="score" target="band"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f7" style="endArrow=block;html=1;" edge="1" parent="1" source="band" target="allow"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f8" style="endArrow=block;html=1;" edge="1" parent="1" source="band" target="stepup"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f9" style="endArrow=block;html=1;" edge="1" parent="1" source="band" target="critical"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f10" style="endArrow=block;html=1;strokeColor=#9673a6;" edge="1" parent="1" source="band" target="store"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f11" style="endArrow=block;html=1;strokeColor=#b85450;" edge="1" parent="1" source="critical" target="case"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f12" style="endArrow=block;html=1;strokeColor=#b85450;" edge="1" parent="1" source="hardblock" target="case"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f13" style="endArrow=block;html=1;" edge="1" parent="1" source="case" target="label"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f14" value="feedback loop" style="endArrow=block;html=1;dashed=1;strokeColor=#6c8ebf;" edge="1" parent="1" source="cb" target="label"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
