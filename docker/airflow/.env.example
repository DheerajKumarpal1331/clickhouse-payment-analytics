# Airflow env (consumed by all four airflow-* services via x-airflow-common)
AIRFLOW_IMAGE=apache/airflow:2.9.3
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=false
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
# DAGs connect out to these (Airflow Variables ch_url / pg_dsn override per-env):
PG_DSN=postgresql://payments:payments_secret@postgres:5432/payments
CH_URL=http://analytics:analytics_secret@clickhouse:8123
# fraud_training dispatches this image (python -m ml.train); set when running the ml profile:
TRAIN_IMAGE=payments-fraud-training:latest
TRAIN_CMD=python -m ml.train
# extra pip libs for the stock Airflow image (DAGs need none by default):
_PIP_ADDITIONAL_REQUIREMENTS=
