<!-- Listen on all interfaces so the HTTP (8123) and native (9000) ports are
     reachable from other containers and the host.

     IMPORTANT: mounting a config.d directory overlays the image's own
     docker_related_config.xml (which normally sets this), so we must restate
     listen_host here or ClickHouse falls back to loopback-only and every
     external HTTP request is reset. -->
<clickhouse>
    <listen_host>0.0.0.0</listen_host>
</clickhouse>
