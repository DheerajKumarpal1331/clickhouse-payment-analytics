{
  "uid": "docker-health",
  "title": "Docker Health",
  "tags": ["platform", "docker"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "Container CPU (cores)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A",
        "expr": "sum(rate(container_cpu_usage_seconds_total{name=~\"payments-.*\"}[5m])) by (name)",
        "legendFormat": "{{name}}" } ]
    },
    {
      "id": 2, "type": "timeseries", "title": "Container Memory (bytes)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [ { "refId": "A",
        "expr": "container_memory_usage_bytes{name=~\"payments-.*\"}",
        "legendFormat": "{{name}}" } ]
    },
    {
      "id": 3, "type": "timeseries", "title": "Network throughput (rx/tx)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(container_network_receive_bytes_total{name=~\"payments-.*\"}[5m])) by (name)", "legendFormat": "rx {{name}}" },
        { "refId": "B", "expr": "sum(rate(container_network_transmit_bytes_total{name=~\"payments-.*\"}[5m])) by (name)", "legendFormat": "tx {{name}}" }
      ]
    },
    {
      "id": 4, "type": "stat", "title": "Host disk used %",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "targets": [ { "refId": "A",
        "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/host\"} / node_filesystem_size_bytes{mountpoint=\"/host\"} * 100)" } ]
    }
  ]
}
