{
  "uid": "kafka-overview",
  "title": "Kafka",
  "tags": ["platform", "kafka"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Brokers online",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "kafka_brokers" } ]
    },
    {
      "id": 2, "type": "stat", "title": "Topics",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "count(count by (topic)(kafka_topic_partitions))" } ]
    },
    {
      "id": 3, "type": "timeseries", "title": "Consumer lag by topic",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A",
        "expr": "sum(kafka_consumergroup_lag) by (topic, consumergroup)",
        "legendFormat": "{{topic}} / {{consumergroup}}" } ]
    },
    {
      "id": 4, "type": "timeseries", "title": "Messages in per topic (rate)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A",
        "expr": "sum(rate(kafka_topic_partition_current_offset[5m])) by (topic)",
        "legendFormat": "{{topic}}" } ]
    }
  ]
}
